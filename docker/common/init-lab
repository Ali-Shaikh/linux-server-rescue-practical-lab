#!/usr/bin/env bash
set -Eeuo pipefail

readonly active_file="/var/lib/cloudsprocket-lab/active-drill"
readonly runtime_installer="/opt/lab/runtime/install.sh"
readonly restore_dir="/opt/lab/drills/restore"

if [[ ! -f "${runtime_installer}" ]]; then
  printf 'ERROR: mounted runtime installer is missing: %s\n' "${runtime_installer}" >&2
  exit 1
fi

bash "${runtime_installer}"

if [[ -f "${active_file}" ]]; then
  active_drill="$(<"${active_file}")"
  if [[ "${active_drill}" =~ ^[0-9]{2}-[a-z0-9]+(-[a-z0-9]+)*$ ]] \
    && [[ -f "${restore_dir}/${active_drill}.sh" ]]; then
    bash "${restore_dir}/${active_drill}.sh"
  else
    printf 'WARN: unknown saved drill %s was not restored.\n' "${active_drill}" >&2
  fi
fi

exec /sbin/init
