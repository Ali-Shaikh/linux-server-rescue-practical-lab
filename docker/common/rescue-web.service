[Unit]
Description=Linux Server Rescue practice web service
After=network.target

[Service]
Type=simple
User=rescue
Group=rescue
Environment=APP_PORT=8080
Environment=APP_DATA_DIR=/var/lib/rescue-web
ExecStart=/usr/bin/python3 /opt/rescue-web/server.py
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target
